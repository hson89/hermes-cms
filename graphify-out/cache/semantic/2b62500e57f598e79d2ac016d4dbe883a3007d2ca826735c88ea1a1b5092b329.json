{"nodes": [{"id": "003_define_content_types_research_research", "label": "Define Content Types Technical Decisions and Rationale", "file_type": "document", "source_file": "specs/003-define-content-types/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "003_define_content_types_research_dynamic_validation", "label": "Dynamic Content Validation Strategy", "file_type": "rationale", "source_file": "specs/003-define-content-types/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Validate user input at the application layer in beforeValidate hooks against the active ContentType schema. Avoid hot-reloading Next.js/Payload configurations in production."}, {"id": "003_define_content_types_research_ai_self_correction", "label": "AI Suggestion Self-Correction Loop", "file_type": "rationale", "source_file": "specs/003-define-content-types/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FastAPI microservice validates LLM output using Pydantic. If validation fails, it triggers a self-correction prompt (up to 3 retries) with specific parser errors before returning to the UI."}, {"id": "003_define_content_types_research_destructive_changes", "label": "Destructive Schema Change Lock", "file_type": "rationale", "source_file": "specs/003-define-content-types/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Block destructive changes (deletions, incompatible type updates) on published Content Types if they already contain Content Items, to prevent data corruption."}, {"id": "003_define_content_types_research_optimistic_concurrency", "label": "Optimistic Concurrency Control", "file_type": "rationale", "source_file": "specs/003-define-content-types/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Compare updatedAt timestamp from client-submitted data with DB value on save. Reject with 409 Conflict if mismatch to prevent last-write-wins collisions."}], "edges": [{"source": "003_define_content_types_research_research", "target": "003_define_content_types_spec_spec", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "specs/003-define-content-types/research.md", "source_location": null, "weight": 1.0}, {"source": "003_define_content_types_research_dynamic_validation", "target": "contentitems_validation_validatefields", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/003-define-content-types/research.md", "source_location": null, "weight": 1.0}, {"source": "003_define_content_types_research_ai_self_correction", "target": "application_ai_service_aiservice", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/003-define-content-types/research.md", "source_location": null, "weight": 1.0}, {"source": "003_define_content_types_research_destructive_changes", "target": "contenttypes_hooks_beforechange", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/003-define-content-types/research.md", "source_location": null, "weight": 1.0}, {"source": "003_define_content_types_research_optimistic_concurrency", "target": "contenttypes_hooks_beforechange", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/003-define-content-types/research.md", "source_location": null, "weight": 1.0}], "hyperedges": []}