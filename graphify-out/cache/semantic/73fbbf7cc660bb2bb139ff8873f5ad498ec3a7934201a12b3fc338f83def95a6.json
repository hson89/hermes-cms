{"nodes": [{"id": "001_ai_headless_cms_research_language_version_decision", "label": "Decision: Hybrid Language Stack", "file_type": "rationale", "source_file": "specs/001-ai-headless-cms/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Python (3.12+) is selected for the AI Microservice as the industry standard for AI, ML, and data engineering, offering the most robust ecosystem (LangChain, LangGraph) and broad support for LLM providers. TypeScript (Node.js 24+) is used for the CMS monolith to utilize the Next.js/Payload ecosystem."}, {"id": "001_ai_headless_cms_research_multi_tenancy_decision", "label": "Decision: Logical Multi-Tenancy", "file_type": "rationale", "source_file": "specs/001-ai-headless-cms/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Payload's official multi-tenant plugin handles mapping and access control in the CMS, while the AI microservice respects these tenant boundaries by associating all sessions and generated data with the incoming tenantId."}, {"id": "001_ai_headless_cms_research_comms_decision", "label": "Decision: Inter-Service Communication", "file_type": "rationale", "source_file": "specs/001-ai-headless-cms/research.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Use asynchronous events via Message Broker (Kafka/RabbitMQ) for generation events, combined with synchronous internal REST APIs for CMS-AI microservice interactions."}], "edges": [{"source": "001_ai_headless_cms_research_language_version_decision", "target": "001_ai_headless_cms_plan_implementation_plan", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/001-ai-headless-cms/research.md", "source_location": null, "weight": 1.0}, {"source": "001_ai_headless_cms_research_multi_tenancy_decisi