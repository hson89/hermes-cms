{"nodes": [{"id": "docs_architecture_content_management_engine", "label": "Content Management Engine (CMS Monolith)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Payload CMS monolith is utilized to handle UI, collections, multi-tenancy, and session persistence in a logical multi-tenancy model to guarantee 0% cross-tenant data bleed."}, {"id": "docs_architecture_template_builder_engine", "label": "Template Builder Engine", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_content_authoring_service", "label": "Content Authoring Service (AI Microservice)", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_sse_content_drafting_flow", "label": "SSE Content Drafting Flow", "file_type": "rationale", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The flow utilizes unidirectional HTTP Server-Sent Events (SSE) where Next.js proxies user actions to FastAPI and streams structured events like TEXT_DELTA, FIELD_START, FIELD_COMPLETE, and DRAFT_COMPLETE."}, {"id": "docs_architecture_single_user_session_locking_and_recovery", "label": "Single-User Session Locking & Recovery", "file_type": "rationale", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "To prevent concurrent editing conflicts while preserving data safety, a compound partial unique index on PostgreSQL ensures only one user has an active session per content schema inside a tenant, with dynamic lockout checks and a 24-hour recovery window."}, {"id": "docs_architecture_distributed_tracing_and_prompt_management", "label": "Distributed Tracing & Prompt Management", "file_type": "rationale", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Next.js establishes a parent trace in Langfuse, propagating it to FastAPI via headers, while decoupling system prompts into a dynamic catalog hosted in Langfuse."}, {"id": "docs_architecture_postgres_backed_sliding_window_rate_limiting", "label": "Postgres-Backed Sliding-Window Rate Limiting", "file_type": "rationale", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Limits user actions to 10 per minute using a global user-scoped collection, bypassing tenant filters to control AI credit consumption and platform costs."}, {"id": "docs_architecture_inter_service_security", "label": "Inter-Service Security", "file_type": "concept", "source_file": "docs/architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_architecture_content_management_engine", "target": "content_management_engine_readme_content_management_engine", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/architecture.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture_content_authoring_service", "target": "content_authoring_service_readme_content_authoring_service", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "docs/architecture.md", "source_location": null, "weight": 1.0}, {"source": "docs_architecture_content_management_engine", "target": "docs_architecture_content_authoring_service", "relation": "conceptually_related