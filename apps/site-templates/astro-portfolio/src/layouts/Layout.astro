---
import '@fontsource/material-symbols-outlined';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts: Inter, Noto Serif, Public Sans (imported via global.css via Astro CSS bundling) -->
		<!-- Material Symbols Outlined imported via @fontsource/material-symbols-outlined npm package -->
	</head>
	<body>
		<header class="portfolio-header">
			<nav class="portfolio-nav">
				<a href="#" class="nav-logo">HERMES PORTFOLIO</a>
				<div class="nav-links">
					<span class="nav-status-badge">ONLINE INDEX</span>
				</div>
			</nav>
		</header>
		<slot />
		<footer class="portfolio-footer">
			<p>© 2026 Hermes AI. The Archival Showcase. Crafted in Alexandria.</p>
		</footer>
	</body>
</html>
