---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hermes AI Architecture Archive">
	<main class="root-container">
		<section class="hero-section">
			<h1 class="hero-title">High-fidelity systems built for the digital age.</h1>
			<p class="hero-bio">
				Welcome to the multi-tenant architecture archive. Please navigate to a specific workspace to view curated project specifications.
			</p>
			
			<div class="discovery-box">
				<p class="discovery-label">ACTIVE DISCOVERY</p>
				<p class="discovery-example">
					Example: <a href="/frontend-demo-5656" class="discovery-link">/frontend-demo-5656</a>
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.root-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 80vh;
		text-align: center;
		padding: 2rem;
	}

	.discovery-box {
		margin-top: 4rem;
		padding: 2rem;
		background: var(--surface-container-low);
		border: 1px solid var(--outline-variant);
		border-radius: 1.5rem;
		max-width: 400px;
		width: 100%;
	}

	.discovery-label {
		font-size: 0.65rem;
		font-weight: 700;
		color: var(--outline);
		letter-spacing: 0.2em;
		margin-bottom: 1rem;
	}

	.discovery-example {
		font-size: 0.875rem;
		color: var(--on-surface-variant);
		font-style: italic;
	}

	.discovery-link {
		color: var(--primary);
		text-decoration: none;
		font-weight: 600;
		font-style: normal;
	}

	.discovery-link:hover {
		text-decoration: underline;
	}
</style>
