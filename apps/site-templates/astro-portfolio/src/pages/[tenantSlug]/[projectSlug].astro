---
import { getTenantBySlug, fetchProjectBySlug, fetchActiveTemplateForSite } from '../../lib/cms';

const { tenantSlug, projectSlug } = Astro.params;

if (!tenantSlug || !projectSlug) {
	return Astro.redirect('/');
}

// 1. Resolve Tenant
const tenant = await getTenantBySlug(tenantSlug);
if (!tenant) {
	return new Response(null, {
		status: 404,
		statusText: 'Tenant Not Found'
	});
}

// 2. Fetch Project
const project = await fetchProjectBySlug(tenant.id, projectSlug);
if (!project) {
	return new Response(null, {
		status: 404,
		statusText: 'Project Not Found'
	});
}

// 3. Fetch deployed template if any
const contentTypeInput = typeof project.contentType === 'object' && project.contentType !== null
  ? (project.contentType.slug || project.contentType.id)
  : project.contentType;

const templateHtml = await fetchActiveTemplateForSite(tenant.id, contentTypeInput || 'project');

if (templateHtml) {
	// Format date
	const formattedDate = new Date(project.createdAt).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});

	// Render the project content to HTML format
	let contentHtml = '';
	if (project.content) {
		if (typeof project.content === 'string') {
			contentHtml = project.content;
		} else {
			// Fallback for JSON structure
			contentHtml = `
				<div class="structured-content-fallback" style="text-align: left; max-width: 600px; margin: 0 auto; padding: 2rem; border-radius: 1.5rem; background: var(--surface-container-low); border: 1px solid var(--outline-variant);">
					<p class="fallback-note" style="font-size: 0.75rem; font-weight: 700; color: var(--outline); text-transform: uppercase; margin-bottom: 1rem;">Technical Specification (JSON Format):</p>
					<pre style="font-size: 0.875rem; overflow-x: auto; white-space: pre-wrap;">${JSON.stringify(project.content, null, 2)}</pre>
				</div>
			`;
		}
	} else {
		contentHtml = `<p class="empty-state-note" style="text-align: center; font-style: italic; color: var(--outline);">The architectural narrative for this project is currently unavailable.</p>`;
	}

	// Interpolate placeholders in the HTML template
	let compiledHtml = templateHtml;

	// Resolve custom fields for rendering
	let featuredImageUrl = '';
	if (project.fieldsData && project.fieldsData.featuredImage) {
		const img = project.fieldsData.featuredImage;
		if (typeof img === 'object' && img !== null) {
			featuredImageUrl = img.url || '';
		} else {
			featuredImageUrl = String(img);
		}
	}
	if (!featuredImageUrl) {
		featuredImageUrl = 'https://lh3.googleusercontent.com/aida-public/AB6AXuA8TFItxn5bgAyRZuJFDyCJGo1f45JYN2uTtJIY9hHlpDqA3ItX9VqhvUf0dud24FTjuzv2XLn4Jutr0wnQ1fR5LVdhQOKbC1x53mOeDihcY3JqH3S4TQGYu-s0l0NQbdLQW37jcBmEjGmuovPZeXzeva1ycMp2tOOZshmx9xSq60H_9jgxPqCAeVfPtmmaxzAvk8HhYW3zrKp4z2dmJPJeOjnde6RISD2Zy1rn2qZbzhcpM2xTLFd00_HzPgCd60-gHlFepCjIwlnA';
	}

	let authorName = 'Aurelian Automotive';
	const author = project.fieldsData?.author;
	if (author) {
		if (typeof author === 'object' && author !== null) {
			authorName = author.name || author.email || 'Aurelian Automotive';
		} else {
			const PAYLOAD_URL = import.meta.env.PAYLOAD_URL || 'http://localhost:3000';
			const API_KEY = import.meta.env.PAYLOAD_API_KEY;
			if (API_KEY) {
				try {
					const userRes = await fetch(`${PAYLOAD_URL}/api/users/${author}`, {
						headers: {
							'Authorization': `api-keys API-Key ${API_KEY}`,
							'Content-Type': 'application/json',
						}
					});
					if (userRes.ok) {
						const userData = await userRes.json();
						authorName = userData.name || userData.email || 'Aurelian Automotive';
					} else {
						console.error(`Error fetching author details: status ${userRes.status} ${userRes.statusText}`);
					}
				} catch (e) {
					console.error('Error fetching author details:', e);
				}
			}
		}
	}

	let tagsHtml = '';
	if (Array.isArray(project.fieldsData?.tags)) {
		tagsHtml = project.fieldsData.tags
			.map((t: any) => {
				const name = typeof t === 'object' && t !== null ? t.name : String(t);
				return `<span class="bg-surface-container hover:bg-surface-variant text-on-surface px-4 py-2 rounded-full text-xs font-label-md transition-colors duration-300 border border-outline-variant/10">${name}</span>`;
			})
			.join('\n');
	}

	compiledHtml = compiledHtml.replace(/\{\{\s*title\s*\}\}/g, project.title || '');
	compiledHtml = compiledHtml.replace(/\{\{\s*excerpt\s*\}\}/g, project.excerpt || '');
	compiledHtml = compiledHtml.replace(/\{\{\s*date\s*\}\}/g, formattedDate);
	compiledHtml = compiledHtml.replace(/\{\{\s*content\s*\}\}/g, contentHtml);
	compiledHtml = compiledHtml.replace(/\{\{\s*featuredImage\s*\}\}/g, featuredImageUrl);
	compiledHtml = compiledHtml.replace(/\{\{\s*author\s*\}\}/g, authorName);
	compiledHtml = compiledHtml.replace(/\{\{\s*tags\s*\}\}/g, tagsHtml);

	// Dynamic replacement for custom fields (e.g. model, engine, horsepower, topSpeed, price, etc.)
	if (project.fieldsData && typeof project.fieldsData === 'object') {
		Object.entries(project.fieldsData).forEach(([key, val]) => {
			// Skip keys that we manually resolved to prevent overriding with raw IDs/JSON
			if (['featuredImage', 'author', 'tags'].includes(key)) return;

			const stringVal = typeof val === 'object' && val !== null ? JSON.stringify(val) : String(val ?? '');
			// Escape regex special characters in the key
			const escapedKey = key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
			const regex = new RegExp(`\\{\\{\\s*${escapedKey}\\s*\\}\\}`, 'g');
			compiledHtml = compiledHtml.replace(regex, stringVal);
		});
	}

	return new Response(compiledHtml, {
		headers: {
			'Content-Type': 'text/html; charset=utf-8'
		}
	});
}
---

<Layout title={`${project.title} | ${tenant.name}`}>
	<main class="project-detail-container">
		<header class="project-header">
			<div class="project-nav">
				<a href={`/${tenantSlug}`} class="back-link">
					<span class="material-symbols-outlined">arrow_back</span>
					BACK TO SHOWCASE
				</a>
				<span class="project-meta-date">
					{new Date(project.createdAt).toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</span>
			</div>
			
			<div class="project-title-section">
				<span class="project-category-badge">{project.category}</span>
				<h1 class="project-title">{project.title}</h1>
				{project.excerpt && <p class="project-excerpt">{project.excerpt}</p>}
			</div>
		</header>

		<section class="project-body">
			{project.content ? (
				typeof project.content === 'string' ? (
					<div set:html={project.content} />
				) : (
					<div class="structured-content-fallback">
						<p class="fallback-note">Technical Specification (JSON Format):</p>
						<pre>{JSON.stringify(project.content, null, 2)}</pre>
					</div>
				)
			) : (
				<p class="empty-state-note">The architectural narrative for this project is currently unavailable.</p>
			)}
		</section>

		<footer class="project-footer">
			<div class="footer-badge">
				<span class="material-symbols-outlined">auto_awesome</span>
				<p>ORCHESTRATED VIA HERMES AI</p>
			</div>
			<a href={`/${tenantSlug}`} class="footer-cta">EXPLORE MORE FROM {tenant.name.toUpperCase()}</a>
		</footer>
	</main>
</Layout>

<style>
	.project-detail-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 4rem 2rem 8rem;
		font-family: 'Inter', sans-serif;
	}

	.project-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 4rem;
	}

	.back-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--primary);
		letter-spacing: 0.1em;
		transition: opacity 0.2s;
	}

	.back-link:hover {
		opacity: 0.7;
	}

	.project-meta-date {
		font-size: 0.65rem;
		font-family: monospace;
		color: var(--outline);
		text-transform: uppercase;
	}

	.project-category-badge {
		display: inline-block;
		font-size: 0.65rem;
		font-weight: 700;
		color: var(--tertiary);
		border: 1px solid rgba(109, 94, 0, 0.2);
		padding: 0.25rem 0.75rem;
		border-radius: 100px;
		margin-bottom: 1.5rem;
		letter-spacing: 0.05em;
	}

	.project-title {
		font-family: 'Noto Serif', serif;
		font-size: 4rem;
		font-weight: 300;
		line-height: 1.1;
		color: var(--on-surface);
		margin-bottom: 2rem;
		letter-spacing: -0.02em;
	}

	.project-excerpt {
		font-size: 1.25rem;
		line-height: 1.6;
		color: var(--on-surface-variant);
		border-left: 2px solid var(--primary);
		padding-left: 1.5rem;
		margin-bottom: 4rem;
		font-style: italic;
	}

	.project-body {
		font-size: 1.125rem;
		line-height: 1.8;
		color: var(--on-surface);
	}

	.structured-content-fallback {
		background: var(--surface-container-low);
		padding: 2rem;
		border-radius: 1.5rem;
		border: 1px solid var(--outline-variant);
	}

	.fallback-note {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--outline);
		margin-bottom: 1rem;
		text-transform: uppercase;
	}

	pre {
		font-size: 0.875rem;
		overflow-x: auto;
		white-space: pre-wrap;
	}

	.project-footer {
		margin-top: 8rem;
		padding-top: 4rem;
		border-top: 1px solid var(--outline-variant);
		text-align: center;
	}

	.footer-badge {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 2rem;
		opacity: 0.5;
	}

	.footer-badge p {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.2em;
	}

	.footer-cta {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--primary);
		text-decoration: none;
	}

	.footer-cta:hover {
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.project-title {
			font-size: 2.5rem;
		}
	}
</style>
