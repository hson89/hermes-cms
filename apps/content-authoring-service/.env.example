DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/hermes_authoring
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
INTERNAL_SERVICE_SECRET=hermes-internal-secret

# LLM Configuration
LANGCHAIN_MODEL_PROVIDER=openai
LANGCHAIN_MODEL=gpt-4o-mini
LANGCHAIN_ENDPOINT_URL=http://localhost:11434/v1 # Optional: e.g. for Ollama or LM Studio

# Image Configuration
BYPASS_IMAGE_GENERATION=true # Set to true to bypass DALL-E image generation and use premium placeholders instead (recommended for local development)
IMAGE_MODEL_PROVIDER=openai
IMAGE_MODEL=dall-e-3
IMAGE_ENDPOINT_URL= # Optional: Custom endpoint for image generation
FALLBACK_IMAGE_URL=https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1024&auto=format&fit=crop&q=80 # Fallback/placeholder image for testing and bypass


# Provider Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
MISTRAL_API_KEY=your-mistral-api-key
